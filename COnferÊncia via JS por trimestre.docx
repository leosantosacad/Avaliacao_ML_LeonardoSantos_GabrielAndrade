
TINTA ACRILICA
CÓDIGO:
let x = [ 
    1, 2, 3, 4
];

let y = [
  400,590,620,950
];

let n = x.length;

let somaX = 0;
let somaY = 0;
let somaXY = 0;
let somaX2 = 0;

for (let i = 0; i < n; i++) {
  somaX += x[i];
  somaY += y[i];
  somaXY += x[i] * y[i];
  somaX2 += x[i] * x[i];
}

let a = (n * somaXY - somaX * somaY) / (n * somaX2 - somaX * somaX);
let b = (somaY - a * somaX) / n;

let mediaY = somaY / n;

let sqTotal = 0;
let sqRes = 0;

for (let i = 0; i < n; i++) {
  let yEstimado = a * x[i] + b;

  sqTotal += Math.pow(y[i] - mediaY, 2);
  sqRes += Math.pow(y[i] - yEstimado, 2);
}

let r2 = 1 - sqRes / sqTotal;

console.log("Equação da reta: y = " + a.toFixed(2) + "x + " + b.toFixed(2));
console.log("R² = " + r2.toFixed(4));

//Previsões para os próximos 3 meses
let futurosX = [5,6,7];

console.log("\nPrevisões:");

for (let i = 0; i < futurosX.length; i++) {
  let xFuturo = futurosX[i];
  let yPrevisto = a * xFuturo + b;

  console.log(
    "Mês " + xFuturo + ": " + yPrevisto.toFixed(2)
  );
}
RESULTADO:
Equação da reta: y = 168.00x + 220.00
R² = 0.9011

Previsões:
Mês 5: 724.00
Mês 6: 892.00
Mês 7: 1060.00

=== Code Execution Successful ===
